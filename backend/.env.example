# Environment variables for RiskRoom Backend
# Copy this file to .env and fill in your actual values

# ─── API Keys ────────────────────────────────────────────────────────────────
# Anthropic API Key (for AI insights via backend)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Slack Webhook URL (optional - for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# SendGrid API Key (for email notifications)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# ─── URLs ────────────────────────────────────────────────────────────────────
# Backend URL (auto-configured on Railway, set manually for localhost)
BACKEND_URL=http://localhost:8000

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Airia Configuration (configure when deployed to Railway)
AIRIA_API_URL=https://api.airia.ai/v1
AIRIA_API_KEY=your_airia_api_key_here

# ─── Simulation Settings ─────────────────────────────────────────────────────
MONTE_CARLO_ITERATIONS=500

# ─── Email Settings (SendGrid) ───────────────────────────────────────────────
EMAIL_FROM=noreply@riskroom.ai
EMAIL_FROM_NAME=RiskRoom

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
